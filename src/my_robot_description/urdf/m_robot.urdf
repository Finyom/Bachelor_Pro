<?xml version="1.0"?>
<robot name="m_robot" xmlns:xacro="http://ros.org/wiki/xacro">

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.5 0.3 0.14" />
      </geometry>
      <material name="Orange">
        <color rgba="0 0 1 1" />
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.5 0.3 0.14" />
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0" />
      <origin xyz="0 0 0.1" />
      <inertia ixx="0.054" iyy="0.116" izz="0.142" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <gazebo reference="base_link">
    <mu1>0.5</mu1>
    <mu2>0.5</mu2>
    <material name="Orange">Gazebo/Orange</material>
  </gazebo>

  <joint name="base_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/> 
  </joint>

  <link name="rear_left_wheel">
    <visual>
      <origin rpy="1.5708 0 0"/>  
      <geometry>
        <cylinder radius="0.05" length="0.02" />
      </geometry>
      <material name="Black">
          <color rgba="0 0 0 0" />
      </material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0"/>      
      <geometry>
        <cylinder radius="0.05" length="0.02" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1" />
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
    </inertial>
  </link>

  <gazebo reference="rear_left_wheel">
    <material name="Black">Gazebo/Black</material>
  </gazebo>


  <link name="rear_right_wheel">
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.02" />
      </geometry>
      <material name="Black">
          <color rgba="0 0 0 0" />
      </material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.02" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1" />
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
    </inertial>
  </link>

  <gazebo reference="rear_right_wheel">
    <material name="Black">Gazebo/Black</material>
  </gazebo>

  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link" />
    <child link="rear_left_wheel" />
    <origin xyz="-0.1 -0.17 -0.05"/>
    <axis xyz="0 1 0" />
  </joint>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link" />
    <child link="rear_right_wheel" />
    <origin xyz="-0.1 0.17 -0.05"/>
    <axis xyz="0 1 0" />
  </joint>

  <gazebo reference="rear_left_wheel">
    <mu1>4.0</mu1>
    <mu2>4.0</mu2>
  </gazebo>

  <gazebo reference="rear_right_wheel">
    <mu1>4.0</mu1>
    <mu2>4.0</mu2>
  </gazebo>



  <link name="caster_wheel">
    <visual>
      <geometry><sphere radius="0.015"/></geometry>
      <material name="Black">
          <color rgba="0 1 1 1" />
      </material>
    </visual>
    <collision>
      <geometry><sphere radius="0.015"/></geometry>
      <material name="blue">
        <color rgba="0 1 1 1" />
      </material>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <gazebo reference="caster_wheel">
    <material name="Black">Gazebo/Black</material>
  </gazebo>

  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="0.19 0 -0.085" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.05"/>
      </geometry>
      <material name="Red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.09" rpy="0 0 0"/>
  </joint>

  <gazebo reference="lidar_link">
    <sensor type="ray" name="lidar_sensor">
    
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14</min_angle>
            <max_angle>3.14</max_angle>
          </horizontal>
        </scan>
        <range>
          <resolution>1</resolution>
          <min>0.3</min>
          <max>8.0</max>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <plugin filename="libgazebo_ros_ray_sensor.so" name="lidar_plugin">
        <ros>
          <namespace>/</namespace>
          <remapping>~/out:=/scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
      
    </sensor>
    <material>Gazebo/Red</material>
  </gazebo>

    <!-- Camera Link -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.05 0.1 0.05"/>
      </geometry>
      <material name="Blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.05 0.1 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
              iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!-- Camera Joint -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.23 0 0.041" rpy="0 0 0"/>
  </joint>

  <!-- Optical Frame -->
  <link name="camera_optical_link"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_link"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- Gazebo Depth Camera Plugin -->
  <gazebo reference="camera_link">
    <sensor type="depth" name="depth_camera">
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
      </camera>
      <plugin filename="libgazebo_ros_camera.so" name="camera_plugin">
        <ros>
          <remapping>~/image_raw:=/camera/image_raw</remapping>
          <remapping>~/depth/image_raw:=/camera/depth/image_raw</remapping>
          <remapping>~/points:=/camera/points</remapping>
        </ros>
        <frame_name>camera_optical_link</frame_name>  
        <min_depth>0.1</min_depth>
        <max_depth>10.0</max_depth>
      </plugin>
    </sensor>
  </gazebo>

  <!-- *********** DIFF-DRIVE (KOMPLETT!) ********** -->
  <gazebo>
    <plugin name="diff_drive_base_controller" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <remapping>odom:=/diff_drive_base_controller/odom</remapping>
      </ros>
      <left_joint>rear_right_wheel_joint </left_joint>
      <right_joint>rear_left_wheel_joint</right_joint>
      <wheel_separation>0.34</wheel_separation>
      <wheel_diameter>0.1</wheel_diameter>       
      <max_wheel_torque>30</max_wheel_torque>
      <max_wheel_acceleration>5</max_wheel_acceleration>
      <command_topic>/cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <robot_base_frame>base_footprint</robot_base_frame>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>    <!-- fix: EKF macht TF! -->
    </plugin>
  </gazebo>

  <!-- Joint States für RViz -->
  <gazebo>
    <plugin name="joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <ros>
        <remapping>~/out:=/joint_states</remapping>
      </ros>
      <update_rate>50</update_rate>
      <joint_name>rear_left_wheel_joint</joint_name>
      <joint_name>rear_right_wheel_joint</joint_name>
    </plugin>
  </gazebo>
  

</robot>